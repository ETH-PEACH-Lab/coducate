{
    "name": "coducate",
    "displayName": "Coducate",
    "description": "A VS Code extension to Streamline Instructor-Led Live Coding",
    "version": "0.2.0",
    "publisher": "coducate",
    "icon": "public/coducate-logo-128.png",
    "galleryBanner": {
        "color": "#1e1e1e",
        "theme": "light"
    },
    "author": {
        "name": "Lukas Mast",
        "email": "lukasmast07@gmail.com"
    },
    "homepage": "https://delta.peachhub-cntr1.inf.ethz.ch",
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "coducate.startSession",
                "title": "Coducate: Start Session"
            },
            {
                "command": "coducate.endSession",
                "title": "Coducate: End Session"
            },
            {
                "command": "coducate.manageSessions",
                "title": "Coducate: Manage Sessions"
            },
            {
                "command": "coducate.grantWriteAccess",
                "title": "Coducate: Grant Write Access"
            },
            {
                "command": "coducate.revokeWriteAccess",
                "title": "Coducate: Revoke Write Access"
            },
            {
                "command": "coducate.emulateTerminal",
                "title": "Coducate: Emulate Terminal"
            },
            {
                "command": "coducate.openTerminal",
                "title": "Coducate: Open Terminal"
            },
            {
                "command": "coducate.closeTerminal",
                "title": "Coducate: Close Terminal"
            },
            {
                "command": "coducate.openExplorer",
                "title": "Coducate: Open Explorer"
            },
            {
                "command": "coducate.closeExplorer",
                "title": "Coducate: Close Explorer"
            },
            {
                "command": "coducate.changeFontSize",
                "title": "Coducate: Change Font Size"
            },
            {
                "command": "coducate.changeTheme",
                "title": "Coducate: Change Theme"
            },
            {
                "command": "coducate.createNote",
                "title": "Coducate: Create Note"
            },
            {
                "command": "coducate.removeNotes",
                "title": "Coducate: Remove Notes"
            },
            {
                "command": "coducate.toggleSuggestions",
                "title": "Coducate: Toggle Suggestions"
            }
        ],
        "keybindings": [
            {
                "key": "ctrl+shift+u",
                "mac": "ctrl+shift+u",
                "command": "coducate.toggleSuggestions"
            },
            {
                "key": "ctrl+shift+right",
                "mac": "cmd+shift+right",
                "command": "editor.action.inlineSuggest.acceptNextLine",
                "when": "inlineSuggestionVisible && !editorReadonly"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.8",
        "@types/node": "20.x",
        "@types/vscode": "^1.95.0",
        "@types/ws": "^8.5.12",
        "@typescript-eslint/eslint-plugin": "^8.7.0",
        "@typescript-eslint/parser": "^8.7.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.1",
        "esbuild": "^0.24.0",
        "eslint": "^9.11.1",
        "npm-run-all": "^2.1.0",
        "typescript": "^5.6.2"
    },
    "dependencies": {
        "@vscode/prompt-tsx": "^0.3.0-alpha.13",
        "unique-names-generator": "^4.7.1",
        "ws": "^8.18.0",
        "y-websocket": "^2.0.4",
        "yjs": "^13.6.20"
    }
}
