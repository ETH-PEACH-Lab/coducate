{
    "name": "coducate",
    "displayName": "Coducate",
    "description": "Streamlines Instructor-Led Live Coding",
    "version": "0.8.2",
    "license": "AGPL-3.0-or-later",
    "publisher": "coducate",
    "icon": "public/coducate-logo.png",
    "galleryBanner": {
        "color": "#1e1e1e",
        "theme": "dark"
    },
    "homepage": "https://coducate.live",
    "repository": {
        "type": "git",
        "url": "https://github.com/ETH-PEACH-Lab/coducate.git"
    },
    "author": {
        "name": "Lukas Mast",
        "email": "lukasmast07@gmail.com",
        "url": "https://www.linkedin.com/in/lukas-mast/"
    },
    "maintainers": [
        {
            "name": "Lukas Mast",
            "email": "lukasmast07@gmail.com",
            "url": "https://www.linkedin.com/in/lukas-mast/"
        }
    ],
    "bugs": {
        "email": "lukasmast07@gmail.com"
    },
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Education"
    ],
    "keywords": [
        "live coding",
        "education",
        "instructor-led",
        "collaboration",
        "code sharing",
        "teaching",
        "pair programming"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "coducate-panel",
                    "title": "Coducate",
                    "icon": "public/coducate-logo.png"
                }
            ]
        },
        "views": {
            "coducate-panel": [
                {
                    "id": "coducateControlPanel",
                    "name": "Control Panel",
                    "icon": "public/coducate-logo.png"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "Coducate",
            "properties": {
                "coducate.exclusion.excludedDirectories": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "node_modules",
                        ".git",
                        "dist",
                        "build",
                        ".vscode",
                        "coverage",
                        "out",
                        "tmp",
                        "logs",
                        ".cache",
                        "__pycache__",
                        ".DS_Store",
                        ".idea",
                        ".next",
                        ".expo",
                        "venv",
                        "target"
                    ],
                    "description": "Directories to exclude from syncing."
                },
                "coducate.exclusion.excludedFilePatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ".coducate.json",
                        ".DS_Store",
                        ".env",
                        ".env.local",
                        ".env.development",
                        ".env.production",
                        ".env.test",
                        ".env.example",
                        ".ipynb"
                    ],
                    "description": "File name patterns (suffixes) to exclude from syncing."
                },
                "coducate.terminal.mirrorOnlyCoducateTerminals": {
                    "type": "boolean",
                    "default": true,
                    "description": "If enabled, only terminals of type 'Coducate Terminal' will be mirrored to the web view.\nWarning: If disabled, ALL integrated terminals will be mirrored to the web view."
                }
            }
        },
        "commands": [
            {
                "command": "coducate.startSession",
                "title": "Coducate: Start Session"
            },
            {
                "command": "coducate.endSession",
                "title": "Coducate: End Session"
            },
            {
                "command": "coducate.manageSessions",
                "title": "Coducate: Manage Sessions"
            },
            {
                "command": "coducate.grantWriteAccess",
                "title": "Coducate: Grant Write Access"
            },
            {
                "command": "coducate.revokeWriteAccess",
                "title": "Coducate: Revoke Write Access"
            },
            {
                "command": "coducate.createCoducateTerminal",
                "title": "Coducate: Create Coducate Terminal"
            },
            {
                "command": "coducate.openTerminal",
                "title": "Coducate: Open Terminal"
            },
            {
                "command": "coducate.closeTerminal",
                "title": "Coducate: Close Terminal"
            },
            {
                "command": "coducate.openExplorer",
                "title": "Coducate: Open Explorer"
            },
            {
                "command": "coducate.closeExplorer",
                "title": "Coducate: Close Explorer"
            },
            {
                "command": "coducate.showRoomId",
                "title": "Coducate: Show Room ID"
            },
            {
                "command": "coducate.hideRoomId",
                "title": "Coducate: Hide Room ID"
            },
            {
                "command": "coducate.changeFontSize",
                "title": "Coducate: Change Font Size"
            },
            {
                "command": "coducate.changeTheme",
                "title": "Coducate: Change Theme"
            },
            {
                "command": "coducate.increaseFontSize",
                "title": "Coducate: Increase Font Size"
            },
            {
                "command": "coducate.decreaseFontSize",
                "title": "Coducate: Decrease Font Size"
            },
            {
                "command": "coducate.setLightTheme",
                "title": "Coducate: Light Theme"
            },
            {
                "command": "coducate.setDarkTheme",
                "title": "Coducate: Dark Theme"
            },
            {
                "command": "coducate.createNote",
                "title": "Coducate: Create Note"
            },
            {
                "command": "coducate.removeNotes",
                "title": "Coducate: Remove Notes"
            },
            {
                "command": "coducate.toggleSuggestions",
                "title": "Coducate: Toggle Suggestions"
            },
            {
                "command": "coducate.exportSession",
                "title": "Coducate: Export Session"
            },
            {
                "command": "coducate.reviewChanges",
                "title": "Coducate: Review Changes"
            }
        ],
        "terminal": {
            "profiles": [
                {
                    "id": "coducate.coducate-terminal",
                    "title": "Coducate Terminal"
                }
            ]
        },
        "keybindings": [
            {
                "key": "ctrl+shift+u",
                "mac": "ctrl+shift+u",
                "command": "coducate.toggleSuggestions"
            },
            {
                "key": "ctrl+shift+right",
                "mac": "cmd+shift+right",
                "command": "editor.action.inlineSuggest.acceptNextLine",
                "when": "inlineSuggestionVisible && !editorReadonly"
            }
        ],
        "icons": {
            "coducate-dark-mode": {
                "description": "Dark mode icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e900"
                }
            },
            "coducate-delete": {
                "description": "Delete icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e901"
                }
            },
            "coducate-file": {
                "description": "File icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e902"
                }
            },
            "coducate-light-mode": {
                "description": "Light mode icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e903"
                }
            },
            "coducate-password": {
                "description": "Password icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e904"
                }
            },
            "coducate-people-add": {
                "description": "People add icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e905"
                }
            },
            "coducate-people-delete": {
                "description": "People delete icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e906"
                }
            },
            "coducate-person-add": {
                "description": "Person add icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e907"
                }
            },
            "coducate-person-delete": {
                "description": "Person delete icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e908"
                }
            },
            "coducate-rename": {
                "description": "Rename icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e909"
                }
            },
            "coducate-workspace": {
                "description": "Workspace icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e90a"
                }
            },
            "coducate-increase": {
                "description": "Increase icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e90b"
                }
            },
            "coducate-decrease": {
                "description": "Decrease icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e90c"
                }
            },
            "coducate-create": {
                "description": "Create icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e90d"
                }
            },
            "coducate-join": {
                "description": "Join icon for Coducate",
                "default": {
                    "fontPath": "public/coducate-icons.woff",
                    "fontCharacter": "\\e90e"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.8",
        "@types/node": "22.x",
        "@types/vscode": "^1.95.0",
        "@types/ws": "^8.5.12",
        "@typescript-eslint/eslint-plugin": "^8.7.0",
        "@typescript-eslint/parser": "^8.7.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.1",
        "esbuild": "^0.25.0",
        "eslint": "^9.11.1",
        "npm-run-all": "^2.1.0",
        "typescript": "^5.6.2"
    },
    "dependencies": {
        "@vscode/prompt-tsx": "^0.3.0-alpha.13",
        "jszip": "^3.10.1",
        "reconnecting-websocket": "^4.4.0",
        "unique-names-generator": "^4.7.1",
        "ws": "^8.18.0",
        "y-websocket": "^2.0.4",
        "yjs": "^13.6.20"
    }
}
